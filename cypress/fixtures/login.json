{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "oneOf": [
    {
      "type": "object",
      "required": ["message", "authorization"],
      "properties": {
        "message": { "type": "string" },
        "authorization": { "type": "string" }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["message"],
      "not": {
        "required": ["authorization"]
      },
      "properties": {
        "message": { "type": "string" }
      },
      "additionalProperties": true
    }
  ]
}
